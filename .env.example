# Base URL for your internal OpenAI-compatible LLM server
# Example: http://llm-server.local:8000/v1
INTERNAL_LLM_URL=

# Base URL for lab custom API (non-OpenAI). Implement lab_adapter.py at the office.
# Example: http://host.docker.internal:11434/v1
LAB_LLM_URL=

# API key for default lab adapter (OpenAI-compatible httpx reference)
# LAB_OPENAI_API_KEY=ollama

# --- Proxy / offline office (copy to .env and fill in) ---
# HTTP_PROXY=http://proxy.corp.example:8080
# HTTPS_PROXY=http://proxy.corp.example:8080
# NO_PROXY=localhost,127.0.0.1,host.docker.internal,.corp.example
# Internal PyPI mirror (optional; used by make pip-cache and Docker build fallback)
# PIP_INDEX_URL=https://pypi.corp.example/simple

# Optional env vars for lab_adapter.build_headers() (document in lab_adapter.py):
# LAB_LLM_SOMETHING=
